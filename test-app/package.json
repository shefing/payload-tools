{
  "name": "@shefing/dev-app",
  "version": "1.0.0",
  "description": "Shared dev/test app for all @shefing payload-tools plugins",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devgd": "cross-env NODE_OPTIONS=--no-deprecation pnpm generate:types && cross-env NODE_OPTIONS=--no-deprecation pnpm generate:importmap && cross-env NODE_OPTIONS=\"--inspect --no-deprecation\" next dev --turbo ",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "chrome:debug": "/Applications/Google\\ Chrome.app/Contents/MacOS/Google\\ Chrome --remote-debugging-port=9222 http://localhost:3000"
  },
  "dependencies": {
    "@payloadcms/db-mongodb": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/ui": "3.84.1",
    "@shefing/authorization": "workspace:*",
    "@shefing/authors-info": "workspace:*",
    "@shefing/color-picker": "workspace:*",
    "@shefing/comments": "workspace:*",
    "@shefing/cover-image": "workspace:*",
    "@shefing/cross-collection": "workspace:*",
    "@shefing/custom-version-view": "workspace:*",
    "@shefing/field-type-component-override": "workspace:*",
    "@shefing/icon-select": "workspace:*",
    "@shefing/quickfilter": "workspace:*",
    "@shefing/reset-list-view": "workspace:*",
    "@shefing/changes-button": "workspace:*",
    "@shefing/right-panel": "workspace:*",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "graphql": "^16.8.1",
    "next": "16.2.3",
    "payload": "3.84.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "0.34.2"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@testing-library/react": "16.3.0",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "@swc-node/register": "1.10.9",
    "@swc/cli": "0.6.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.3",
    "jsdom": "28.0.0",
    "postcss": "^8.4.47",
    "prettier": "^3.4.2",
    "sass": "^1.80.0",
    "tailwindcss": "^3.4.14",
    "tailwindcss-scoped-preflight": "^3.4.6",
    "tsx": "4.21.0",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
